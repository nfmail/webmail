msgstr "A felület bemutatása"

#. js-lingui-explicit-id
msgid "tour.restart_title"
msgstr "Bevezető bemutató"

#. js-lingui-explicit-id
msgid "tour.restart_desc"
msgstr "A vezetett bemutató újrajátszása"

#. js-lingui-explicit-id
msgid "tour.restart_button"
msgstr "Bemutató újraindítása"

#. js-lingui-explicit-id
msgid "tour.show_on_new_devices_title"
msgstr "Megjelenítés új eszközökön"

#. js-lingui-explicit-id
msgid "tour.show_on_new_devices_desc"
msgstr "Az üdvözlő banner és bemutató újrajátszása, amikor először jelentkezel be egy új eszközön, még ha már elvégezted máshol"

#. js-lingui-explicit-id
msgid "tour.sidebar_title"
msgstr "Postafiókjaid"

#. js-lingui-explicit-id
msgid "tour.sidebar_desc"
msgstr "Ez a mappa oldalsávod. Kattints bármely postafiókra az e-mailek megtekintéséhez. Létrehozhatsz mappákat, húzhatsz e-maileket közöttük, és egy pillantással láthatod az olvasatlanok számát."

#. js-lingui-explicit-id
msgid "tour.compose_title"
msgstr "E-mail írása"

#. js-lingui-explicit-id
msgid "tour.compose_desc"
msgstr "Kattints ide egy új e-mail írásához. Hozzáadhatsz címzetteket, csatolmányokat, és használhatsz formázott szöveget."

#. js-lingui-explicit-id
msgid "tour.search_title"
msgstr "Keresés a levelek között"

#. js-lingui-explicit-id
msgid "tour.search_desc"
msgstr "Keresés feladó, tárgy vagy tartalom alapján. Kattints a szűrő ikonra a speciális opciókért, mint dátumtartomány, csatolmányok és csillagozott üzenetek."

#. js-lingui-explicit-id
msgid "tour.email_list_title"
msgstr "E-mail listád"

#. js-lingui-explicit-id
msgid "tour.email_list_desc"
msgstr "Az e-mailek itt jelennek meg. Kattints egyre az olvasáshoz a jobb oldalon. Használd a jelölőnégyzetet több kijelöléséhez, majd tömeges áthelyezéshez, törléshez vagy címkézéshez."

#. js-lingui-explicit-id
msgid "tour.email_viewer_title"
msgstr "Olvasóablak"

#. js-lingui-explicit-id
msgid "tour.email_viewer_desc"
msgstr "A kiválasztott e-mail itt nyílik meg. Válaszolj, továbbíts, archiválj vagy törölj az eszköztár gombjaival. Csillagozhatsz is, vagy színes címkéket adhatsz hozzá."

#. js-lingui-explicit-id
msgid "tour.keywords_title"
msgstr "Színes címkék"

#. js-lingui-explicit-id
msgid "tour.keywords_desc"
msgstr "E-mailek rendezése színkódolt címkékkel. Húzz egy e-mailt egy címkére a felcímkézéshez, vagy kattints jobb gombbal egy e-mailre a címkék hozzárendeléséhez."

#. js-lingui-explicit-id
msgid "tour.calendar_title"
msgstr "Naptár"

#. js-lingui-explicit-id
msgid "tour.calendar_desc"
msgstr "Válts a naptárra az események kezeléséhez. Hozz létre eseményeket, állíts be emlékeztetőket, és nézd meg a nap, hét vagy hónap elrendezést."

#. js-lingui-explicit-id
msgid "tour.contacts_title"
msgstr "Névjegyek"

#. js-lingui-explicit-id
msgid "tour.contacts_desc"
msgstr "A címjegyzéked itt található. Importálj névjegyeket, hozz létre csoportokat, és kattints bármely névjegyre a teljes adatainak megtekintéséhez."

#. js-lingui-explicit-id
msgid "tour.settings_title"
msgstr "Beállítások"

#. js-lingui-explicit-id
msgid "tour.settings_desc"
msgstr "Testreszabhatsz mindent: témát, sűrűséget, aláírásokat, szűrőket, billentyűparancsokat, naptár alapértelmezetteket és még sok mást."

#. js-lingui-explicit-id
msgid "tour.shortcuts_title"
msgstr "Billentyűparancsok"

#. js-lingui-explicit-id
msgid "tour.shortcuts_desc"
msgstr "A haladó felhasználók imádni fogják. Nyomd meg a ? gombot bármikor az összes elérhető parancs megtekintéséhez. Navigálhatsz, írhatsz és kezelheted az e-maileket egér nélkül."

#. js-lingui-explicit-id
msgid "tour.compose_open_title"
msgstr "A szerkesztő"

#. js-lingui-explicit-id
msgid "tour.compose_open_desc"
msgstr "Ez az e-mail szerkesztő. Adj hozzá címzetteket, írd meg az üzeneted, csatolj fájlokat, és használj formázott szöveget. Piszkozatokat is menthetsz és sablonokat használhatsz."

#. js-lingui-explicit-id
msgid "tour.calendar_view_title"
msgstr "Naptárad"

#. js-lingui-explicit-id
msgid "tour.calendar_view_desc"
msgstr "Itt a naptárad minta eseményekkel. Válthatsz nap, hét, hónap és napirend nézetek között az eszköztár segítségével."

#. js-lingui-explicit-id
msgid "tour.create_event_title"
msgstr "Esemény létrehozása"

#. js-lingui-explicit-id
msgid "tour.create_event_desc"
msgstr "Kattints erre a gombra egy új naptári esemény létrehozásához. Beállíthatsz címet, dátumot, időpontot, és résztvevőket adhatsz hozzá."

#. js-lingui-explicit-id
msgid "tour.event_modal_title"
msgstr "Esemény részletei"

#. js-lingui-explicit-id
msgid "tour.event_modal_desc"
msgstr "Itt az esemény űrlap. Töltsd ki a címet, válassz dátumot és időpontot, adj hozzá helyszínt vagy résztvevőket. Nyomj a Mentés gombra ha kész, vagy zárd be és lépj tovább."

#. js-lingui-explicit-id
msgid "tour.contacts_list_title"
msgstr "Névjegyeid"

#. js-lingui-explicit-id
msgid "tour.contacts_list_desc"
msgstr "Itt vannak a névjegyeid. Kattints bármelyikre a teljes adatainak megtekintéséhez a jobb oldalon. Létrehozhatsz új névjegyeket, importálhatsz vCard-okat, vagy csoportokba rendezheted a névjegyeket."

#. js-lingui-explicit-id
msgid "tour.settings_tabs_title"
msgstr "Beállítások menü"

#. js-lingui-explicit-id
msgid "tour.settings_tabs_desc"
msgstr "Itt vannak az összes beállítás kategória. Testreszabhatod a megjelenést, kezelheted az azonosságokat, beállíthatsz e-mail szűrőket, konfigurálhatod a naptárat és még sok mást."

#. js-lingui-explicit-id
msgid "tour.files_title"
msgstr "Fájltároló"

#. js-lingui-explicit-id
msgid "tour.files_desc"
msgstr "A fájlböngésződ lehetővé teszi fájlok feltöltését, rendezését és megosztását - mint egy személyes felhőmeghajtó a levelezésedbe építve."

#. js-lingui-explicit-id
msgid "tour.demo_banner_title"
msgstr "Demó vezérlők"

#. js-lingui-explicit-id
msgid "tour.demo_banner_desc"
msgstr "Demó módban vagy - minden a böngésződben marad. Nyomd meg a 'Demó visszaállítása' gombot bármikor a tiszta mintaadatokkal való újrakezdéshez."

#. js-lingui-explicit-id
msgid "tour.quota_title"
msgstr "Tárhely használat"

#. js-lingui-explicit-id
msgid "tour.quota_desc"
msgstr "Kövesd nyomon a postafiókod méretét itt. A kör kitöltődik, ahogy egyre több helyet használsz."

