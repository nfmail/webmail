{
  "name": "nf-mail",
  "version": "1.7.7-nf.1",
  "description": "NF Mail - a modern, self-hosted webmail client built for Stalwart Mail Server",
  "author": "NF Mail contributors",
  "license": "AGPL-3.0-only",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "24.14.1",
    "npm": "11.11.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nfmail/webmail.git"
  },
  "homepage": "https://github.com/nfmail/webmail",
  "bugs": {
    "url": "https://github.com/nfmail/webmail/issues"
  },
  "keywords": [
    "jmap",
    "webmail",
    "stalwart",
    "email",
    "nextjs",
    "react",
    "typescript"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "check:nf": "node scripts/check-nf.mjs",
    "check:ruleset": "node scripts/check-ruleset.mjs",
    "check:toolchain": "node scripts/check-toolchain.mjs",
    "check:ui": "node scripts/check-ui-conventions.mjs",
    "i18n:compile": "lingui compile",
    "check:i18n": "npm run i18n:compile && git diff --exit-code -- 'locales/*/messages.ts'",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots=all",
    "test:a11y": "playwright test --config=playwright.a11y.config.ts",
    "test:nf": "node --test scripts/check-nf.test.mjs",
    "test:ui-check": "node --test scripts/check-ui-conventions.test.mjs",
    "test:translations": "vitest run --no-isolate lib/__tests__/translations.test.ts",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lingui/core": "^6.5.0",
    "@lingui/react": "^6.5.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "asn1js": "^3.0.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.12",
    "jalaali-js": "^2.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "otpauth": "^9.5.0",
    "pdfjs-dist": "^6.0.227",
    "pkijs": "^3.4.0",
    "postal-mime": "^2.7.4",
    "pvtsutils": "^1.3.6",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.6.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "undici": "^7.28.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.4",
    "@lingui/cli": "^6.5.0",
    "@lingui/format-po": "^6.5.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@swc/helpers": "^0.5.23",
    "flatted": "^3.4.2",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.19",
    "undici": "^7.28.0"
  }
}
